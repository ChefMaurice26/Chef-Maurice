*{box-sizing:border-box}body{margin:0;font-family:Arial;background:linear-gradient(135deg,#4a2817,#98623b);color:#181818}.app{max-width:1100px;min-height:100vh;margin:auto;background:#fff7ed}header{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:12px 18px;background:#171717;color:white}header nav{display:flex;gap:8px}button{border:0;border-radius:11px;padding:11px 14px;font-weight:800;cursor:pointer;background:#f47b20;color:white}.link{background:transparent;color:#9a4a18}small{background:#f47b20;padding:3px 7px;border-radius:999px}main{padding:24px}.hero{background:linear-gradient(110deg,#2e180c,#824823);color:white;padding:35px;border-radius:26px;display:grid;grid-template-columns:1fr .7fr;align-items:center}.hero h1{font-size:3.5rem;line-height:1}.chef{font-size:10rem;text-align:center}.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px}.card{background:white;padding:22px;border-radius:18px;box-shadow:0 12px 28px #0002}label{display:grid;gap:5px;margin:10px 0}input{padding:11px;border:1px solid #bbb;border-radius:10px}.notice{grid-column:1/-1;padding:12px;background:#fff0cf;border-radius:12px}@media(max-width:700px){header{flex-direction:column}.hero{grid-template-columns:1fr}.chef{font-size:7rem}}